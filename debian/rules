#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DPHI_ADAPTER_FRITZ_BUILD_IPC=ON \
		-DPHI_ADAPTER_FRITZ_USE_LOCAL_ADAPTER_SDK=OFF

override_dh_shlibdeps:
	dh_shlibdeps -l/usr/lib/aarch64-linux-gnu -l/usr/lib
